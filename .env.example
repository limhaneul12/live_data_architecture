SERVICE_APP_NAME=live-data-api
SERVICE_APP_ENV=local
SERVICE_APP_VERSION=0.1.0
SERVICE_APP_LOG_LEVEL=INFO
SERVICE_EVENT_CONSUMER_ENABLED=false

DATABASE_DB_ADDRESS=postgresql://live_data:live_data@localhost:15432/live_data
# Optional: SQL Lab/Explore 전용 read-only DB role을 분리할 때만 설정합니다.
# ANALYTICS_DATABASE_DB_ADDRESS=postgresql://analytics_reader:analytics_reader@localhost:15432/live_data

STREAM_REDIS_URL=redis://localhost:16379/0
STREAM_REDIS_MODE=single
STREAM_BATCH_SIZE=100
STREAM_BLOCK_MS=1000

APP_PORT=8000
FRONTEND_PORT=3000
POSTGRES_PORT=15432
REDIS_PORT=16379
BACKEND_API_BASE_URL=http://localhost:8000
